		writefile(savedKeyFile, key)
	end
end

local function loadSavedKey()
	if readfile and isfile and isfile(savedKeyFile) then
		local success, key = pcall(function()
			return readfile(savedKeyFile)
		end)
		if success and key and key ~= "" then
			return key
		end
	end
	return nil
end

local function deleteSavedKey()
	if delfile and isfile and isfile(savedKeyFile) then
		delfile(savedKeyFile)
	end
end

local function validateKey(key)
	local success, result = pcall(function()
		local url = KEYS_URL .. key
		local response
		
		if syn and syn.request then
			response = syn.request({Url = url, Method = "GET"}).Body
		elseif http and http.request then
			response = http.request({Url = url, Method = "GET"}).Body
		elseif request then
			response = request({Url = url, Method = "GET"}).Body
		else
			response = HttpService:GetAsync(url, true)
		end
		
		local data = HttpService:JSONDecode(response)
		
		-- Verificar si la key existe
		if not data.fields then
			return {valid = false, expired = false}
		end
		
		-- Extraer datos de Firebase
		local active = data.fields.active and data.fields.active.booleanValue or false
		local expirationDate = data.fields.expirationDate and data.fields.expirationDate.stringValue or ""
		
		if not active then
			return {valid = false, expired = true}
		end
		
		-- Verificar si expiró
		local now = os.time()
		local expYear, expMonth, expDay = expirationDate:match("(%d+)-(%d+)-(%d+)")
		if expYear then
			local expTime = os.time({year = tonumber(expYear), month = tonumber(expMonth), day = tonumber(expDay), hour = 23, min = 59, sec = 59})
			if now > expTime then
				return {valid = false, expired = true}
			end
			
			local daysLeft = math.ceil((expTime - now) / 86400)
			return {valid = true, expired = false, expiresAt = expirationDate, daysLeft = daysLeft}
		end
		
		return {valid = true, expired = false, expiresAt = expirationDate}
	end)
	
	if not success then
		return {valid = false, expired = false}
	end
	
	return result
end

