-- Sistema de búsqueda de prompts del Script 1 original (el que sí funcionaba)
local function findNearestPrompt()
    local h = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not h then return nil, nil, nil end
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil, nil, nil end
    local np, nd, nn = nil, math.huge, nil
    for _, plot in ipairs(plots:GetChildren()) do
        if not isMyPlotByName(plot.Name) then
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if podiums then
                for _, pod in ipairs(podiums:GetChildren()) do
                    pcall(function()
                        local base = pod:FindFirstChild("Base")
                        local spawn = base and base:FindFirstChild("Spawn")
                        if spawn then
                            local dist = (spawn.Position - h.Position).Magnitude
                            if dist < nd and dist <= CIRCLE_RADIUS_STEAL then
                                local att = spawn:FindFirstChild("PromptAttachment")
                                if att then
                                    for _, ch in ipairs(att:GetChildren()) do
                                        if ch:IsA("ProximityPrompt") then
                                            np, nd, nn = ch, dist, pod.Name
                                            break
                                        end
                                    end
                                end
                            end
                        end
                    end)
                end
            end
        end
    end
    return np, nd, nn
end

local function shouldSteal(animalData)
    if not animalData or not animalData.worldPosition then return false end
    local hrp = getHRP()
    if not hrp then return false end
    return (hrp.Position - animalData.worldPosition).Magnitude <= CIRCLE_RADIUS_STEAL
end

local StealData = {}

local function triggerPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(workspace) then return end

    prompt.MaxActivationDistance = 9e9
    prompt.RequiresLineOfSight = false
    prompt.ClickablePrompt = true

    -- Cachear los handlers del prompt (sistema del script 1 original)
    if not StealData[prompt] then
        StealData[prompt] = {hold = {}, trigger = {}, ready = true}
        pcall(function()
            if getconnections then
                for _, c in ipairs(getconnections(prompt.PromptButtonHoldBegan)) do
                    if c.Function then table.insert(StealData[prompt].hold, c.Function) end
                end
                for _, c in ipairs(getconnections(prompt.Triggered)) do
                    if c.Function then table.insert(StealData[prompt].trigger, c.Function) end
                end
            end
        end)
    end

    local data = StealData[prompt]
    if not data.ready then return end
    data.ready = false
    IsStealing = true
    StealProgress = 0

    -- Dispara todos los métodos en paralelo
    pcall(function() fireproximityprompt(prompt) end)
    pcall(function() prompt:InputHoldBegin() end)
    pcall(function() prompt:InputHoldEnd() end)
    for _, f in ipairs(data.hold) do task.spawn(f) end
    for _, f in ipairs(data.trigger) do task.spawn(f) end

    -- Respaldo con hold completo
    task.spawn(function()
        pcall(function()
            prompt:InputHoldBegin()
            task.wait(HOLD_DURATION)
            prompt:InputHoldEnd()
        end)
    end)

    -- VISUAL
    task.spawn(function()
        local startTime = tick()
        while tick() - startTime < HOLD_DURATION do
            StealProgress = math.min((tick() - startTime) / HOLD_DURATION, 0.85)
            task.wait(0.016)
        end
        StealProgress = 0.85
        task.wait()
        StealProgress = 1
        task.wait(0.2)
        IsStealing = false
        StealProgress = 0
        data.ready = true
    end)
end

local function getNearestAnimal()
    local hrp = getHRP()
    if not hrp then return nil end
    local nearest = nil
    local minDist = math.huge
    for _, animalData in ipairs(allAnimalsCache) do
        if isMyPlotByName(animalData.plot) then continue end
        if animalData.worldPosition then
            local dist = (hrp.Position - animalData.worldPosition).Magnitude
            if dist < minDist then
                minDist = dist
                nearest = animalData
            end
        end
    end
    return nearest
end

