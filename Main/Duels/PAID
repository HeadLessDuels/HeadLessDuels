local function createSlider(parent, labelText, minVal, maxVal, valueKey, callback)
    local card = makeCard(parent, SS)

    local lbl = Instance.new("TextLabel", card)
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, -50, 0, isMobile and 16 or 20)
    lbl.Position = UDim2.new(0, 10, 0, 3)
    lbl.Text = labelText
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = TS
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextColor3 = CB.text
    lbl.ZIndex = 7

    local defaultVal = Values[valueKey]

    local valLabel = Instance.new("TextLabel", card)
    valLabel.BackgroundTransparency = 1
    valLabel.Size = UDim2.fromOffset(isMobile and 34 or 40, isMobile and 16 or 20)
    valLabel.Position = UDim2.new(1, isMobile and -40 or -46, 0, 3)
    valLabel.Text = tostring(defaultVal)
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextSize = TS
    valLabel.TextColor3 = CB.accent2
    valLabel.ZIndex = 7

    local barH = isMobile and 6 or 7
    local barY  = isMobile and 30 or 36
    local bar = Instance.new("Frame", card)
    bar.Size = UDim2.new(1, -16, 0, barH)
    bar.Position = UDim2.new(0, 8, 0, barY)
    bar.BackgroundColor3 = Color3.fromRGB(20, 34, 56)
    bar.BorderSizePixel = 0
    bar.ZIndex = 7
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    local pct = (defaultVal - minVal) / (maxVal - minVal)
    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = CB.accent
    fill.BorderSizePixel = 0
    fill.ZIndex = 8
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local fg = Instance.new("UIGradient", fill)
    fg.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 90, 210)),
        ColorSequenceKeypoint.new(1, CB.accent2),
    })

    local knobSize = isMobile and 12 or 14
    local knob = Instance.new("Frame", bar)
    knob.Size = UDim2.fromOffset(knobSize, knobSize)
    knob.BackgroundColor3 = Color3.fromRGB(230, 245, 255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 9
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local function setVal(rel)
        rel = math.clamp(rel, 0, 1)
        local value = math.floor(minVal + (maxVal - minVal) * rel)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -knobSize/2, 0.5, -knobSize/2)
        valLabel.Text = tostring(value)
        Values[valueKey] = value
        callback(value)
    end
    setVal(pct)

    local draggingSlider = false
    bar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = true
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not draggingSlider then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement and i.UserInputType ~= Enum.UserInputType.Touch then return end
        setVal((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X)
    end)

    SliderSetters[valueKey] = function(v)
        v = math.clamp(v, minVal, maxVal)
        setVal((v - minVal) / (maxVal - minVal))
    end

    return card
end

