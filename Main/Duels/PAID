local themedBgs    = {}
local themedStrokes = {}
local themedAccents = {}

local function applyMenuColor(color)
    menuColor = color
    galaxySkyColor = color

    local darkR = math.clamp(color.R * 0.6, 0, 1)
    local darkG = math.clamp(color.G * 0.6, 0, 1)
    local darkB = math.clamp(color.B * 0.6, 0, 1)
    local bgColor  = Color3.new(darkR * 0.6, darkG * 0.6, darkB * 0.6)
    local surfColor = Color3.new(darkR * 0.8, darkG * 0.8, darkB * 0.8)
    local cardColor = Color3.new(darkR, darkG, darkB)

    local accentColor = Color3.new(
        math.clamp(color.R * 2.5 + 0.1, 0, 1),
        math.clamp(color.G * 2.5 + 0.1, 0, 1),
        math.clamp(color.B * 2.5 + 0.1, 0, 1)
    )

    for _, t in ipairs(themedBgs) do
        if t.frame and t.frame.Parent then
            local m = t.mult or 1
            t.frame.BackgroundColor3 = Color3.new(
                math.clamp(bgColor.R * m, 0, 1),
                math.clamp(bgColor.G * m, 0, 1),
                math.clamp(bgColor.B * m, 0, 1)
            )
        end
    end
    for _, s in ipairs(themedStrokes) do
        if s and s.Parent then s.Color = accentColor end
    end
    for _, a in ipairs(themedAccents) do
        if a and a.Parent then a.BackgroundColor3 = accentColor end
    end

    CB.bg      = bgColor
    CB.surface = surfColor
    CB.card    = cardColor
    CB.accent  = accentColor
    CB.accent2 = Color3.new(
        math.clamp(accentColor.R + 0.1, 0, 1),
        math.clamp(accentColor.G + 0.1, 0, 1),
        math.clamp(accentColor.B + 0.1, 0, 1)
    )
    CB.rain   = accentColor
    CB.stroke = Color3.new(darkR * 0.5, darkG * 0.5, darkB * 0.5)
end

